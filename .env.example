# Copy this file to ".env" and fill in your Anthropic API key.
#   cp .env.example .env
#
# Get a key at https://console.anthropic.com/ (Settings → API Keys).
# Vite only exposes variables prefixed with VITE_ to the browser.
# Restart the dev server after creating or changing .env.
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
